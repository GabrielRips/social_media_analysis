# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Meta (Facebook + Instagram) ───────────────────────────────────────────────
# Get from: https://developers.facebook.com → Graph API Explorer
META_ACCESS_TOKEN=EAA...
META_API_VERSION=v21.0
FACEBOOK_PAGE_ID=123456789
INSTAGRAM_USER_ID=17841400000000

# ── TikTok ────────────────────────────────────────────────────────────────────
# Get from: https://developers.tiktok.com → Manage Apps → OAuth
TIKTOK_ACCESS_TOKEN=act.xxx

# ── YouTube ───────────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=AIza...
YOUTUBE_CHANNEL_ID=UC...

# For replying to comments (optional — needs service account or OAuth2)
YOUTUBE_SERVICE_ACCOUNT_EMAIL=
YOUTUBE_SERVICE_ACCOUNT_KEY=

# For uploading videos (OAuth2 — run `node youtube-auth.mjs` to get refresh token)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Twitter/X ─────────────────────────────────────────────────────────────────
# Get from: https://developer.x.com → Dashboard → Keys and Tokens
TWITTER_BEARER_TOKEN=AAAA...
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USER_ID=

# ── Google Docs (for analytics reports) ───────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Docs API and Google Drive API
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DOC_ID=

# ── Agent Settings ────────────────────────────────────────────────────────────
# Cron schedule for the daily analytics sweep (default: 7am daily)
CRON_SCHEDULE=0 7 * * *
TIMEZONE=Australia/Melbourne

# Port for the review dashboard
REVIEW_PORT=3456
